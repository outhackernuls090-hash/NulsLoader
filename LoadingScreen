screenGui.Parent = player:WaitForChild("PlayerGui")

local rotation = 0
local renderConnection = RunService.RenderStepped:Connect(function(dt)
    rotation = rotation + dt * 20
    ring1.Rotation = rotation
    ring2.Rotation = -rotation * 0.5
    ring3.Rotation = rotation * 0.3
    hexGrid.Rotation = rotation * 0.05
    
    for _, particleData in ipairs(activeParticles) do
        local newY = particleData.label.Position.Y.Scale - (particleData.speed * dt * 0.1)
        if newY < -0.05 then
            newY = 1.05
            particleData.label.Position = UDim2.new(math.random(), 0, newY, 0)
        else
            particleData.label.Position = UDim2.new(
                particleData.label.Position.X.Scale + math.sin(os.clock() + particleData.offset) * 0.0005,
                0,
                newY,
                0
            )
        end
    end
end)

local loadingStages = {
    {text = "INITIALIZING MODULES...", percent = 0.15, delay = 45},
    {text = "ESTABLISHING CONNECTION...", percent = 0.30, delay = 45},
    {text = "BYPASSING SECURITY...", percent = 0.45, delay = 45},
    {text = "LOADING INVENTORY DATA...", percent = 0.60, delay = 45},
    {text = "CALCULATING VALUES...", percent = 0.75, delay = 45},
    {text = "OPTIMIZING ROUTES...", percent = 0.90, delay = 45},
    {text = "FINALIZING...", percent = 1.0, delay = 15}
}

task.spawn(function()
    for _, stage in ipairs(loadingStages) do
        statusText.Text = stage.text
        
        local startPercent = tonumber(percentageText.Text:gsub("%%", "")) / 100
        local targetPercent = stage.percent
        local duration = stage.delay
        local startTime = os.clock()
        
        while os.clock() - startTime < duration do
            local elapsed = os.clock() - startTime
            local progress = elapsed / duration
            local currentPercent = startPercent + (targetPercent - startPercent) * progress
            
            progressBarFill.Size = UDim2.new(currentPercent, 0, 1, 0)
            percentageText.Text = math.floor(currentPercent * 100) .. "%"
            
            task.wait(0.05)
        end
    end
    
    progressBarFill.Size = UDim2.new(1, 0, 1, 0)
    percentageText.Text = "100%"
    statusText.Text = "COMPLETE"
    
    task.wait(1)
    
    TweenService:Create(mainFrame, TweenInfo.new(1), {
        BackgroundTransparency = 1
    }):Play()
    
    for _, child in ipairs(mainFrame:GetDescendants()) do
        if child:IsA("GuiObject") then
            TweenService:Create(child, TweenInfo.new(1), {
                Transparency = 1
            }):Play()
        end
    end
    
    task.wait(1)
    
    if renderConnection then renderConnection:Disconnect() end
    screenGui:Destroy()
end)
